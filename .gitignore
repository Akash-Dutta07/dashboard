# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Environment variables / secrets — never commit
.env

# Generated by collectstatic — rebuilt anytime, never commit
staticfiles/

# Celery Beat runtime state — regenerated automatically, never commit
celerybeat-schedule*

# Scratch / pasted notes — not part of the app
temp.txt

# Personal teaching / notes (do not push to public repo)
CLAUDE.md
NOTES_*.md
